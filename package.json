{
  "name": "abu-cross-browser-extension",
  "version": "4.1.3",
  "description": "AdBlocker Ultimate Browser Extension",
  "type": "module",
  "scripts": {
    "dev": "cross-env BUILD_ENV=dev node tools/bundle.js",
    "dev:promo": "cross-env BUILD_ENV=dev PROMO_BUILD=true node tools/bundle.js",
    "dev:watch": "cross-env BUILD_ENV=dev node tools/bundle.js chrome --watch",
    "dev:watch:ff": "cross-env BUILD_ENV=dev node tools/bundle.js firefox --watch",
    "release": "cross-env BUILD_ENV=release node tools/bundle.js",
    "release:promo": "cross-env BUILD_ENV=release PROMO_BUILD=true node tools/bundle.js",
    "resources": "node tools/resources.js",
    "resources:mv3": "node tools/resources-mv3.js",
    "lint": "eslint --cache --max-warnings=0 .",
    "lint:fix": "eslint --fix --cache .",
    "increment:patch": "pnpm version patch --no-git-tag-version",
    "increment:minor": "pnpm version minor --no-git-tag-version",
    "increment:major": "pnpm version major --no-git-tag-version",
    "copy-external": "tswebextension war src/resources/web-accessible-resources",
    "convert-declarative": "node tools/converter.js",
    "knip": "knip -c knip.mv3.js && knip -c knip.mv2.js",
    "knip:mv3": "knip -c knip.mv3.js",
    "knip:mv2": "knip -c knip.mv2.js",
    "update-filters": "node tools/update-filters.js"
  },
  "author": "AdAvoid Ltd",
  "license": "GPL-3.0",
  "devDependencies": {
    "@adguard/dnr-rulesets": "~3.2",
    "@adguard/re2-wasm": "1.2.0",
    "@eslint/compat": "^1",
    "@eslint/js": "^9",
    "@stylistic/eslint-plugin": "^2.0.0",
    "@types/node": "^25.2.0",
    "axios": "1.6.2",
    "chalk": "4.1.2",
    "clean-webpack-plugin": "4.0.0",
    "commander": "12.1.0",
    "copy-webpack-plugin": "12.0.2",
    "cross-env": "7.0.3",
    "css-loader": "6.7.3",
    "escape-string-regexp": "4.0.0",
    "eslint": "^9",
    "eslint-plugin-import": "2.27.5",
    "eslint-plugin-import-newlines": "1.3.1",
    "fs-extra": "10.1.0",
    "globals": "^15",
    "html-webpack-plugin": "5.6.3",
    "jsdom": "25.0.1",
    "knip": "^5.83.0",
    "lodash": "4.17.21",
    "mini-css-extract-plugin": "2.9.2",
    "postcss": "8.4.49",
    "postcss-loader": "8.1.1",
    "postcss-nested": "7.0.2",
    "postcss-preset-env": "10.1.2",
    "postcss-svg": "3.0.0",
    "preprocess-loader": "0.3.0",
    "sharp": "^0.33.0",
    "sinon": "19.0.2",
    "sinon-chrome": "3.0.1",
    "source-map-loader": "3.0.2",
    "style-loader": "3.3.2",
    "superjson": "2.2.1",
    "swc-loader": "0.2.3",
    "terser": "5.37.0",
    "typescript": "^5.9.3",
    "vitest": "4.0.15",
    "wait-for-expect": "3.0.2",
    "webpack": "5.97.1",
    "webpack-bundle-analyzer": "4.10.2",
    "webpack-merge": "5.10.0",
    "zip-webpack-plugin": "4.0.3"
  },
  "dependencies": {
    "@adguard/agtree": "3.4.3",
    "@adguard/assistant": "bitbucket:allteamnext/assistant#6f23ada",
    "@adguard/filters-downloader": "2.4.2",
    "@adguard/logger": "^2.0.0",
    "@adguard/scriptlets": "2.2.14",
    "@adguard/text-encoding": "^0.8.3",
    "@adguard/tsurlfilter": "3.5.2",
    "@adguard/tswebextension": "3.2.19",
    "@preact/signals": "^2.7.1",
    "buffer": "6.0.3",
    "core-js": "3.40.0",
    "crypto-browserify": "3.12.0",
    "crypto-js": "4.2.0",
    "file-saver": "^2.0.5",
    "idb": "8.0.2",
    "lodash-es": "4.17.21",
    "nanoid": "3.3.6",
    "preact": "^10.25.0",
    "punycode": "2.3.1",
    "stream-browserify": "3.0.0",
    "tldts": "5.7.112",
    "ua-parser-js": "1.0.36",
    "vm-browserify": "1.1.2",
    "webextension-polyfill": "0.12.0"
  }
}
